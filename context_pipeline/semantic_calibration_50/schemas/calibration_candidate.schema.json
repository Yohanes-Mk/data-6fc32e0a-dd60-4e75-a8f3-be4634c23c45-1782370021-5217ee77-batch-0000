{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage 4E calibration candidate",
  "type": "object",
  "required": [
    "candidate_id","case_id","candidate_type","knowledge_layer","canonical_title","description",
    "why_it_matters","ownership_type","user_role","organizational_context","status","temporal_status",
    "status_current_confidence","first_observed_at","last_observed_at","confidence","confidence_rationale",
    "explicit_or_inferred","transport_author_roles","content_origins","assertion_relationships",
    "assistant_origin","co_authored_flag","user_endorsement","evidence_segment_ids","evidence_message_ids",
    "attachment_ids","document_ids","missing_source_ids","project_test_criteria","competing_classifications",
    "applied_decision_rule_ids","uncertainties","contradictions","requires_human_review","inclusion_rationale"
  ],
  "properties": {
    "candidate_id": {"type": "string"},
    "case_id": {"type": "string"},
    "candidate_type": {"type": "string", "enum": [
      "project","subproject","initiative","recurring_responsibility","course","assignment","exam_preparation",
      "job_application","client_engagement","research_effort","standalone_idea",
      "goal","motivation","requirement","constraint","preference","decision","proposed_decision","task",
      "open_question","milestone","direction_change","blocker","output","artifact","research_question",
      "research_finding","source","workflow","status_update","next_step",
      "person","organization","platform","tool","employer","client","institution",
      "one_off_request","generic_question","assistant_suggestion","assistant_draft","assistant_explanation",
      "tool_execution_trace","attachment_source","transcript_fragment","unresolved_fragment"
    ]},
    "knowledge_layer": {"type": "string", "enum": ["work_entity","project_knowledge","context_entity","non_project_interaction"]},
    "canonical_title": {"type": "string", "minLength": 4},
    "description": {"type": "string"},
    "why_it_matters": {"type": "string"},
    "ownership_type": {"type": "string", "enum": ["user_owned","group_owned","personal_or_family","client_owned_user_responsible","third_party","unknown","not_applicable"]},
    "user_role": {"type": "string"},
    "organizational_context": {"type": ["string","null"]},
    "status": {"type": "string"},
    "temporal_status": {"type": "string", "enum": ["current_confirmed","current_inferred","historical_confirmed","historical_status_unknown","superseded","unknown","point_in_time"]},
    "status_current_confidence": {"type": "string", "enum": ["high","medium","low"]},
    "first_observed_at": {"type": ["string","null"]},
    "last_observed_at": {"type": ["string","null"]},
    "confidence": {"type": "string", "enum": ["high","medium","low"]},
    "confidence_rationale": {"type": "string", "minLength": 1},
    "explicit_or_inferred": {"type": "string", "enum": ["explicit","inferred","mixed"]},
    "transport_author_roles": {"type": "array", "items": {"type": "string"}},
    "content_origins": {"type": "array", "items": {"type": "string", "enum": ["user_authored","co_authored","assistant_generated","pasted_assistant","tool_or_log_output","transcript_source_material","document","attachment","mixed_origin_co_authored"]}},
    "assertion_relationships": {"type": "array", "items": {"type": "string"}},
    "assistant_origin": {"type": "boolean"},
    "co_authored_flag": {"type": "boolean"},
    "user_endorsement": {"type": "string", "enum": ["explicit_acceptance","explicit_rejection","modification","implicit_continuation","no_endorsement","unclear","not_applicable"]},
    "evidence_segment_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_message_ids": {"type": "array", "items": {"type": "string"}},
    "attachment_ids": {"type": "array", "items": {"type": "string"}},
    "document_ids": {"type": "array", "items": {"type": "string"}},
    "missing_source_ids": {"type": "array", "items": {"type": "string"}},
    "project_test_criteria": {"type": "array", "items": {"type": "string"}},
    "competing_classifications": {"type": "array", "items": {"type": "string"}},
    "applied_decision_rule_ids": {"type": "array", "items": {"type": "string"}},
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "contradictions": {"type": "array", "items": {"type": "string"}},
    "requires_human_review": {"type": "boolean"},
    "review_classification": {"type": ["string","null"], "enum": ["covered_by_existing_rule","new_reusable_rule","case_specific_exception","genuinely_unresolved",null]},
    "inclusion_rationale": {"type": "string"}
  }
}
